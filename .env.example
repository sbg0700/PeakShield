# Copy to `.env` and fill in real values. `.env` is gitignored.

# 공공데이터포털(data.go.kr) 인증키 — 탄소배출권(KAU25) 시세 API용
# 발급: https://www.data.go.kr/ → 마이페이지 → 인증키 발급
DATA_GO_KR_SERVICE_KEY=your_service_key_here

# Flask 대시보드 포트 (기본 5001)
DASHBOARD_PORT=5001

# 대시보드가 읽는 스트리밍 소스 CSV (05 스크립트 산출물)
DASHBOARD_DATA_CSV=../data/processed/final_2026ver.csv
